# --- Anthropic ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model used for SQL generation + answering. Sonnet balances quality and cost.
# For cheaper runs try claude-haiku-4-5-20251001; for hardest queries, claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS=1024

# --- Database ---
# The agent runs read-only queries against this database. A read-only DB role
# is recommended in production (see README); the app also enforces read-only
# at the transaction level regardless.
DATABASE_URL=postgresql://neondb_owner:npg_F0eYsT9uCOGr@ep-floral-shadow-ai9ov923-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Query safety limits ---
MAX_RESULT_ROWS=200
STATEMENT_TIMEOUT_MS=5000

# --- Agent loop ---
MAX_AGENT_STEPS=6
MAX_HISTORY_TURNS=12

# --- CORS ---
# Must match the frontend origin exactly (no trailing slash).
CLIENT_URL=http://localhost:5173
